# ==========================================
# ВСЕ СЕКРЕТЫ ЖИВУТ ЗДЕСЬ, А НЕ В КОДЕ.
# Скопируйте файл как .env и заполните значения.
# .env добавлен в .gitignore и НИКОГДА не коммитится.
# ==========================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/voidcode?schema=public"
JWT_SECRET="сгенерируйте-длинную-случайную-строку"
JWT_EXPIRES_IN="7d"

# Ключи LLM-провайдеров — только на сервере
GEMINI_API_KEY=""
OPENROUTER_API_KEY=""

# Шифрование пользовательских ключей провайдеров (32 байта hex)
PROVIDER_KEY_SECRET=""
